PORT=3000
NODE_ENV=development

# Historical trade import. Runtime reads data/processed after import/build scripts run.
DATASET_SOURCE_PATH=/absolute/path/to/BTC-Trading-Since-2020

# Offline knowledge import source. Runtime uses data/knowledge JSON, not raw PDFs.
KNOWLEDGE_SOURCE_DIR=F:\pdfs

# Market data
BINANCE_BASE_URL=https://api.binance.com
YAHOO_FINANCE_BASE_URL=https://query1.finance.yahoo.com
MARKET_SYMBOL=BTCUSDT
MARKET_INTERVAL=1h
MARKET_LIMIT=120
CACHE_TTL_SECONDS=60

# Macro fallback state. These are deterministic defaults when no live macro provider is configured.
MACRO_REGIME=mixed
MACRO_INFLATION_TREND=stable
MACRO_RATES_TREND=stable
MACRO_VOLATILITY_REGIME=calm
MACRO_EVENT_RISK=low
MACRO_LIQUIDITY=neutral
MACRO_CACHE_TTL_SECONDS=900
# Optional comma-separated dates that raise event risk near CPI/FOMC/NFP/GDP events.
MACRO_EVENT_DATES=

# OGID integration
OGID_ENABLED=false
OGID_BASE_URL=http://dashboard.clobig.com/api
OGID_TIMEOUT_MS=8000

# OpenAI LLM meta layer. Missing key is safe; deterministic output still works.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_MS=8000
